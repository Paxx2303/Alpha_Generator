FROM python:3.11-slim

WORKDIR /app

COPY requirements-observation.txt .
RUN pip install --no-cache-dir -r requirements-observation.txt

COPY . .

EXPOSE 8080
ENV PYTHONPATH=/app

CMD ["streamlit", "run", "observation/app.py", \
     "--server.port=8080", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
