# DeerFlow environment variables
# This file is copied to /app/deer-flow/.env by the GitHub Actions deploy job.
# Do NOT commit real credentials.

# WorldQuant Brain credentials
WQB_EMAIL=your_wqb_email@example.com
WQB_PASSWORD=your_wqb_password

# Ollama (local LLM — runs on the VM, no external service needed)
# Ollama is installed automatically by vm-setup.sh.
# Default model: qwen2.5:14b — change in config.yaml if needed.
OLLAMA_HOST=http://localhost:11434

# DeerFlow API (runner.py uses this to trigger research cycles)
DEERFLOW_URL=http://localhost:8000

# GCS backup bucket (optional)
GCS_BACKUP_BUCKET=gs://alpha-backups-YOUR_PROJECT_ID
