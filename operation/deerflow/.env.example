# DeerFlow environment variables
# Copy to .env and fill in values

# WorldQuant Brain credentials
WQB_EMAIL=your_wqb_email@example.com
WQB_PASSWORD=your_wqb_password

# GLM-5.2 via vLLM on Cloud Run
GLM_BASE_URL=https://alpha-glm-xxxx-uc.a.run.app/v1
GLM_API_KEY=your_internal_token

# GCS backup bucket
GCS_BACKUP_BUCKET=gs://alpha-backups-YOUR_PROJECT_ID

# HuggingFace token (for GLM-5.2 model download)
HF_TOKEN=hf_your_token_here
